# Copy this file to `.env` (same folder) and fill in your key to enable the
# Gemini-powered RAG. Without a key, OpsBrain runs fully offline on local
# deterministic embeddings + template answers — everything still works.
#
# `.env` is git-ignored; never commit your real key.

# Google AI Studio API key (classic AIza... or newer AQ.* format both work).
GEMINI_API_KEY=

# Optional overrides (sensible defaults shown):
# GEMINI_CHAT_MODEL=gemini-3.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_EMBED_DIM=768

# Optional: force Gemini OFF even if a key is present (used by the test suite).
# OPSBRAIN_DISABLE_GEMINI=1

# Optional: use Postgres+pgvector instead of the default local SQLite.
# DATABASE_URL=postgresql+psycopg://opsbrain:opsbrain@localhost:5432/opsbrain
